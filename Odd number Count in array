import java.util.*;
public class Main{
  public static void main(String [] args){
    Scanner sd=new Scanner (System.in);
    int n=sd.nextInt();
    int arr[]=new int [n];
    for(int i=0;i<n;i++){
      arr[i]=sd.nextInt();
    }
    int odd=0;
    for(int i=0;i<n;i++){
      if(arr[i]%2!=0){
          odd++;
      }
      }
System.out.println(odd);
}
}
