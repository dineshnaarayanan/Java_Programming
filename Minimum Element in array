import java.util.*;
public class Main{
  public static void main(String [] args){
    Scanner sd=new Scanner (System.in);
    int n=sd.nextInt();
    int arr []=new int [n];
    for(int i=0;i<n;i++){
      arr[i]=sd.nextInt();  
    }
    int min=Integer.MIN_VALUE();
    for(int i=0;i<n;i++){
      if(min>arr[i]){
        min=arr[i];
    }
}
System.out.println(min);
}
}
