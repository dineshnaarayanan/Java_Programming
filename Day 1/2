Problem 2

Find the sum.

Input

1 2 3 4 5

Output

15


import java.util.*;
public class Main{
public static void main(String [] args){
Scanner sd=new Scanner (System.in);
int n=sd.nextInt();
int arr[]=new int [n];
for(int i=0;i<n;i++){
arr[i]=sd.nextInt();
}
int sum=0;
for(int i=0;i<n;i++){
sum+=arr[i];
}
for(int i=0;i<n;i++){
System.out.println(sum);
}
System.out.println();
}
}
}
}
