import java.util.*;
public class Main{
    public static void main(String [] args){
        Scanner sd=new Scanner (System.in);
        int n=sd.nextInt();
        int arr[]=new int [n];
        for(int i=0;i<n;i++){
            arr[i]=sd.nextInt();
        }
        Arrays.sort(arr);
        int sum=0;
        for(int i=0;i<n;i++){
            if(arr[i]%2==0){
               int temp=arr[i]%10;
               arr[i]=arr[i]/10;
               sum=arr[i]+temp;
               System.out.println(sum);
            }else if(arr[i]%2!=0){
                int temp=arr[i]%10;
                arr[i]=arr[i]/10;
                sum=arr[i]+temp;
                sum=Math.pow(sum,2);
                System.out.println(sum);
                }
               
        }
    }
}
